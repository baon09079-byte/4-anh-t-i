<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Urban Coffee</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-brand text-center">
            <i class="bi bi-cup-hot-fill me-2"></i> Urban Coffee
        </div>

        <div class="px-3 mb-4 text-center">
            <div class="small text-muted mb-1">Đang đăng nhập:</div>
            <div class="text-gold fw-bold">@User.Identity.Name</div>
            <div class="badge bg-gold text-dark mt-1">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
        </div>
        
        <a asp-controller="Home" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
            <i class="bi bi-grid-3x3-gap me-2"></i> Sơ đồ bàn
        </a>
        <a asp-controller="OrderManagement" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "OrderManagement" ? "active" : "")">
            <i class="bi bi-receipt me-2"></i> Đơn hàng
        </a>

        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Menu" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Menu" ? "active" : "")">
                <i class="bi bi-book me-2"></i> Thực đơn
            </a>
        }
        
        <div class="back-btn d-grid gap-2">
            <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger w-100">
                <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
            </a>
        </div>
    </div>

    <div class="main-content">
        <header class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary">
            <h2 class="m-0">@ViewData["Title"]</h2>
            <div class="user-profile text-gold">
                <i class="bi bi-person-circle me-1"></i> Quản lý viên
            </div>
        </header>

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
