@model webcoffee.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<div class="container py-5">
    <div class="row align-items-center">
        <div class="col-md-6 mb-4 mb-md-0">
            <img src="@Model.ImageUrl" class="img-fluid rounded border border-secondary shadow-lg" alt="@Model.Name">
        </div>
        <div class="col-md-6">
            <h1 class="display-4 fw-bold text-neon-pink mb-3">@Model.Name</h1>
            <h4 class="text-muted mb-4">Danh mục: <span class="text-neon-cyan">@Model.Category?.Name</span></h4>
            <p class="lead mb-4">@Model.Description</p>
            <h2 class="text-white mb-4">@Model.Price.ToString("N0") VNĐ</h2>
            
            <div class="d-grid gap-2 d-md-block">
                <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@Model.Id" class="btn btn-neon btn-lg px-5 me-md-2">Thêm vào giỏ</a>
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Quay lại thực đơn</a>
            </div>
        </div>
    </div>
</div>
