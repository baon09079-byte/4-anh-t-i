@model IEnumerable<webcoffee.Models.Product>
@{
    ViewData["Title"] = "Thực Đơn";
    var categories = ViewBag.Categories as List<webcoffee.Models.Category>;
    int? tableId = ViewBag.TableId;
}

<div class="text-center mb-5">
    <h1 class="display-4 text-gold">THỰC ĐƠN</h1>
    @if (tableId.HasValue)
    {
        <h4 class="text-info">Đang gọi món cho: @ViewBag.TableName</h4>
        <a asp-controller="Table" asp-action="Details" asp-route-id="@tableId" class="btn btn-outline-secondary btn-sm mb-3">Quay lại bàn</a>
    }
    <p class="lead text-muted">@ViewBag.CurrentCategory</p>
</div>

<div class="row mb-4 justify-content-center">
    <div class="col-auto">
        <a asp-action="Index" asp-route-tableId="@tableId" class="btn btn-outline-gold m-1 @(ViewBag.CurrentCategory == "Tất cả sản phẩm" ? "active" : "")">Tất cả</a>
        @if (categories != null)
        {
            foreach (var cat in categories)
            {
                <a asp-action="Index" asp-route-categoryId="@cat.Id" asp-route-tableId="@tableId"
                   class="btn btn-outline-gold m-1 @(ViewBag.CurrentCategory == cat.Name ? "active" : "")">
                   @cat.Name
                </a>
            }
        }
    </div>
</div>

<div class="row">
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted">
            <p>Không tìm thấy sản phẩm nào.</p>
        </div>
    }
    
    @foreach (var item in Model)
    {
        <div class="col-md-4 col-lg-3 mb-4">
            <div class="card h-100">
                <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" style="height: 150px; object-fit: cover;">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title text-gold">@item.Name</h5>
                    <p class="card-text text-muted small flex-grow-1">@item.Description</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="fs-6 fw-bold text-white">@item.Price.ToString("N0") VNĐ</span>
                        <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.Id" asp-route-tableId="@tableId" class="btn btn-sm btn-gold">
                            <i class="bi bi-plus-lg"></i> Thêm
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
