@model List<webcoffee.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="card p-4">
    <div class="table-responsive">
        <table class="table table-elegant table-hover align-middle">
            <thead>
                <tr>
                    <th>Mã ĐH</th>
                    <th>Bàn</th>
                    <th>Thời gian</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>#@order.Id</td>
                        <td>@(order.Table?.Name ?? "Mang đi")</td>
                        <td>@order.OrderDate.ToString("HH:mm dd/MM")</td>
                        <td class="text-gold fw-bold">@order.TotalAmount.ToString("N0") VNĐ</td>
                        <td>
                            @switch (order.Status)
                            {
                                case webcoffee.Models.OrderStatus.Moi:
                                    <span class="badge bg-primary">Mới</span>
                                    break;
                                case webcoffee.Models.OrderStatus.DangChuanBi:
                                    <span class="badge bg-warning text-dark">Đang chuẩn bị</span>
                                    break;
                                case webcoffee.Models.OrderStatus.DaPhucVu:
                                    <span class="badge bg-info">Đã phục vụ</span>
                                    break;
                                case webcoffee.Models.OrderStatus.DaThanhToan:
                                    <span class="badge bg-success">Đã thanh toán</span>
                                    break;
                                case webcoffee.Models.OrderStatus.DaHuy:
                                    <span class="badge bg-danger">Đã hủy</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (order.TableId.HasValue)
                            {
                                <a asp-controller="Table" asp-action="Details" asp-route-id="@order.TableId" class="btn btn-sm btn-outline-gold">Chi tiết bàn</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
