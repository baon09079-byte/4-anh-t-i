@model webcoffee.Models.Order
@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container">
    <h2 class="text-neon-pink mb-4">Thanh toán</h2>
    <div class="row">
        <div class="col-md-6 order-md-2 mb-4">
            <h4 class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-neon-cyan">Giỏ hàng của bạn</span>
            </h4>
            <p>Vui lòng kiểm tra lại đơn hàng trước khi xác nhận.</p>
        </div>
        <div class="col-md-6 order-md-1">
            <h4 class="mb-3">Thông tin giao hàng</h4>
            <form asp-action="Checkout" method="post" class="needs-validation" novalidate>
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="CustomerName" class="form-label">Họ và Tên</label>
                        <input asp-for="CustomerName" class="form-control bg-dark text-light border-secondary" required>
                        <span asp-validation-for="CustomerName" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Phone" class="form-label">Số điện thoại</label>
                        <input asp-for="Phone" class="form-control bg-dark text-light border-secondary" required>
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Address" class="form-label">Địa chỉ nhận hàng</label>
                        <input asp-for="Address" class="form-control bg-dark text-light border-secondary" placeholder="Số nhà, tên đường, quận/huyện..." required>
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>
                </div>

                <hr class="my-4 border-secondary">

                <button class="w-100 btn btn-neon btn-lg" type="submit">Đặt Hàng</button>
            </form>
        </div>
    </div>
</div>
