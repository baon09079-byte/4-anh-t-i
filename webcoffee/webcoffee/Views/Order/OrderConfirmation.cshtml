@{
    ViewData["Title"] = "Xác nhận đơn hàng";
}

<div class="container text-center py-5">
    <div class="mb-4">
        <i class="bi bi-check-circle-fill text-neon-cyan display-1"></i>
    </div>
    <h1 class="display-4 text-neon-pink">Đặt hàng thành công!</h1>
    <p class="lead text-light">Cảm ơn bạn đã lựa chọn Urban Coffee.</p>
    <p class="text-muted">Mã đơn hàng của bạn là: <strong class="text-white">#@ViewBag.OrderId</strong></p>
    
    <div class="mt-5">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light me-2">Về Trang Chủ</a>
        <a asp-controller="Menu" asp-action="Index" class="btn btn-neon">Tiếp tục mua sắm</a>
    </div>
</div>
