@model List<webcoffee.Models.Table>
@{
    ViewData["Title"] = "Sơ đồ bàn";
}

<div class="row mb-4">
    <div class="col-md-8">
        <h3 class="text-gold"><i class="bi bi-grid-3x3-gap me-2"></i> Trạng thái bàn hiện tại</h3>
    </div>
    <div class="col-md-4 text-end">
        <span class="badge bg-success me-2">Trống</span>
        <span class="badge bg-gold">Có khách</span>
    </div>
</div>

<div class="table-grid">
    @foreach (var table in Model)
    {
        <div class="card table-card @(table.IsOccupied ? "occupied" : "")" onclick="location.href='@Url.Action("Details", "Table", new { id = table.Id })'">
            <div class="card-body">
                <h4 class="card-title">@table.Name</h4>
                <div class="table-status">
                    @if (table.IsOccupied)
                    {
                        <span class="status-occupied"><i class="bi bi-person-fill"></i> Đang có khách</span>
                    }
                    else
                    {
                        <span class="status-available"><i class="bi bi-check-circle"></i> Sẵn sàng</span>
                    }
                </div>
            </div>
        </div>
    }
</div>

<div class="mt-5 p-4 card">
    <h4 class="mb-3">Thống kê nhanh</h4>
    <div class="row text-center">
        <div class="col-md-4">
            <h2 class="text-gold">@Model.Count</h2>
            <p class="text-muted">Tổng số bàn</p>
        </div>
        <div class="col-md-4">
            <h2 class="text-success">@Model.Count(t => !t.IsOccupied)</h2>
            <p class="text-muted">Bàn trống</p>
        </div>
        <div class="col-md-4">
            <h2 class="text-danger">@Model.Count(t => t.IsOccupied)</h2>
            <p class="text-muted">Bàn đang sử dụng</p>
        </div>
    </div>
</div>
