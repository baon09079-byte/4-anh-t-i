@model IEnumerable<webquanlykhachsan.Models.Room>

@{
    ViewData["Title"] = "Quản Lý Phòng";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Danh Sách Phòng</h1>
        <p>
            <a asp-action="Create" class="btn btn-primary">Thêm Phòng</a>
        </p>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Number)</th>
                        <th>@Html.DisplayNameFor(model => model.Floor)</th>
                        <th>@Html.DisplayNameFor(model => model.Status)</th>
                        <th>@Html.DisplayNameFor(model => model.RoomType)</th>
                        <th>Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
            @foreach (var item in Model) {
                    <tr>
                        <td class="fw-bold">@Html.DisplayFor(modelItem => item.Number)</td>
                        <td>Tầng @Html.DisplayFor(modelItem => item.Floor)</td>
                        <td>
                            @switch (item.Status)
                            {
                                case RoomStatus.Available:
                                    <span class="badge bg-success">Còn Trống</span>
                                    break;
                                case RoomStatus.Occupied:
                                    <span class="badge bg-danger">Đang Ở</span>
                                    break;
                                case RoomStatus.Cleaning:
                                    <span class="badge bg-info">Đang Dọn Dẹp</span>
                                    break;
                                case RoomStatus.Maintenance:
                                    <span class="badge bg-warning">Bảo Trì</span>
                                    break;
                            }
                        </td>
                        <td>@Html.DisplayFor(modelItem => item.RoomType!.Name)</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning">Sửa</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info">Chi Tiết</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Xóa</a>
                            </div>
                        </td>
                    </tr>
            }
                </tbody>
            </table>
        </div>
    </div>
</div>
