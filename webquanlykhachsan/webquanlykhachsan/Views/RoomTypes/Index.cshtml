@model IEnumerable<webquanlykhachsan.Models.RoomType>

@{
    ViewData["Title"] = "Danh Sách Loại Phòng";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Quản Lý Loại Phòng</h1>
        <p>
            <a asp-action="Create" class="btn btn-primary">Thêm Mới</a>
        </p>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Name)</th>
                        <th>@Html.DisplayNameFor(model => model.BasePrice)</th>
                        <th>@Html.DisplayNameFor(model => model.Capacity)</th>
                        <th>Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
            @foreach (var item in Model) {
                    <tr>
                        <td class="fw-bold">@Html.DisplayFor(modelItem => item.Name)</td>
                        <td>@item.BasePrice.ToString("N0") VND</td>
                        <td>@Html.DisplayFor(modelItem => item.Capacity) người</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning">Sửa</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info">Chi Tiết</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Xóa</a>
                            </div>
                        </td>
                    </tr>
            }
                </tbody>
            </table>
        </div>
    </div>
</div>
