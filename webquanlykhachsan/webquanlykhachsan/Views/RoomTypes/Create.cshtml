@model webquanlykhachsan.Models.RoomType

@{
    ViewData["Title"] = "Thêm Loại Phòng";
}

<div class="container py-4">
    <h1>Thêm Loại Phòng Mới</h1>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-3">
                        <label asp-for="Name" class="control-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="BasePrice" class="control-label"></label>
                        <input asp-for="BasePrice" class="form-control" type="number" />
                        <span asp-validation-for="BasePrice" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="control-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Capacity" class="control-label"></label>
                        <input asp-for="Capacity" class="form-control" type="number" />
                        <span asp-validation-for="Capacity" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="control-label"></label>
                        <input asp-for="ImageUrl" class="form-control" />
                        <span asp-validation-for="ImageUrl" class="text-danger"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <input type="submit" value="Lưu Lại" class="btn btn-primary" />
                        <a asp-action="Index" class="btn btn-secondary">Quay Lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
