@{
    ViewData["Title"] = "Trang Chủ";
}

<div class="hero-section">
    <div class="container">
        <h1 class="display-5 fw-bold mb-3">Tìm chỗ nghỉ tiếp theo</h1>
        <p class="lead mb-4">Tìm ưu đãi khách sạn, chỗ nghỉ dạng nhà và nhiều hơn nữa...</p>
        
        <div class="search-box-container">
            <div class="search-box-inner">
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger py-2 mb-3">
                        <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["Error"]
                    </div>
                }
                
                <form asp-controller="Booking" asp-action="Search" method="get" class="row g-3">
                    <div class="col-lg-4">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-bed text-muted"></i></span>
                            <input type="text" class="form-control border-start-0" placeholder="Bạn muốn đến đâu?" readonly value="Khách sạn của chúng tôi">
                        </div>
                    </div>
                    <div class="col-lg-3">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-calendar-days text-muted"></i></span>
                            <input type="date" name="checkIn" class="form-control border-start-0" required min="@DateTime.Now.ToString("yyyy-MM-dd")" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                    <div class="col-lg-3">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-calendar-days text-muted"></i></span>
                            <input type="date" name="checkOut" class="form-control border-start-0" required min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                    <div class="col-lg-2">
                        <button type="submit" class="btn btn-booking w-100 h-100 py-2">Tìm kiếm</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="container mt-5 pt-4">
    <h3 class="fw-bold mb-4">Khám phá các lựa chọn của chúng tôi</h3>
    
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <img src="https://images.unsplash.com/photo-1631049307264-da0ec9d70304?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=60" class="card-img-top" alt="Single Room">
                <div class="card-body">
                    <h5 class="fw-bold">Phòng Single</h5>
                    <p class="text-muted small">1 giường đơn • 1 phòng tắm • 15m²</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <div>
                            <span class="badge bg-success mb-2">Giá tốt nhất</span>
                            <div class="price-tag">500,000 VND</div>
                        </div>
                        <a href="#" class="btn btn-outline-primary btn-sm">Xem chi tiết</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <img src="https://images.unsplash.com/photo-1590490360182-c33d57733427?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=60" class="card-img-top" alt="Double Room">
                <div class="card-body">
                    <h5 class="fw-bold">Phòng Double</h5>
                    <p class="text-muted small">1 giường đôi • 1 phòng tắm • 25m²</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <div>
                            <span class="badge bg-primary mb-2">Phổ biến</span>
                            <div class="price-tag">800,000 VND</div>
                        </div>
                        <a href="#" class="btn btn-outline-primary btn-sm">Xem chi tiết</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <img src="https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=60" class="card-img-top" alt="Suite Room">
                <div class="card-body">
                    <h5 class="fw-bold">Phòng Suite</h5>
                    <p class="text-muted small">1 giường cực lớn • 1 phòng khách • 50m²</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <div>
                            <span class="badge bg-warning text-dark mb-2">Sang trọng</span>
                            <div class="price-tag">2,000,000 VND</div>
                        </div>
                        <a href="#" class="btn btn-outline-primary btn-sm">Xem chi tiết</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="bg-white py-5 mt-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h2 class="fw-bold mb-3">Tiết kiệm thời gian và tiền bạc!</h2>
                <p class="text-muted">Đăng ký để nhận những ưu đãi tốt nhất từ chúng tôi.</p>
                <div class="input-group mb-3" style="max-width: 400px;">
                    <input type="text" class="form-control" placeholder="Địa chỉ email của bạn">
                    <button class="btn btn-booking" type="button">Đăng ký</button>
                </div>
            </div>
            <div class="col-md-6 text-center">
                <div class="p-4 border rounded bg-light">
                    <i class="fa-solid fa-mobile-screen-button fa-3x mb-3 text-primary"></i>
                    <h4>Tải ứng dụng của chúng tôi</h4>
                    <p class="small text-muted">Đặt phòng nhanh hơn và nhận thông báo về các ưu đãi độc quyền.</p>
                </div>
            </div>
        </div>
    </div>
</div>
