@model webquanlykhachsan.Models.Booking

@{
    ViewData["Title"] = "Xác Nhận Đặt Phòng";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-body p-5">
                    <div class="text-center mb-5">
                        <div class="display-1 text-success mb-4">
                            <i class="fa-solid fa-circle-check"></i>
                        </div>
                        <h2 class="fw-bold text-dark">Đặt phòng thành công!</h2>
                        <p class="text-muted lead">Cảm ơn bạn đã lựa chọn khách sạn của chúng tôi cho chuyến đi của mình.</p>
                    </div>

                    <div class="bg-light rounded p-4 mb-4">
                        <h5 class="fw-bold mb-4 border-bottom pb-2 text-primary">Chi tiết đặt phòng #@Model.Id</h5>
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <p class="mb-1 text-muted small">Khách sạn</p>
                                <p class="fw-bold">BookingHotel.com - Chi nhánh Trung tâm</p>
                            </div>
                            <div class="col-sm-6">
                                <p class="mb-1 text-muted small">Loại phòng</p>
                                <p class="fw-bold">@Model.Room?.RoomType?.Name (Phòng @Model.Room?.Number)</p>
                            </div>
                            <div class="col-md-6 border-top pt-3">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="me-3 text-center" style="width: 60px;">
                                        <div class="small text-muted uppercase">NHẬN</div>
                                        <div class="fs-4 fw-bold">@Model.CheckInDate.Day</div>
                                        <div class="small">Tháng @Model.CheckInDate.Month</div>
                                    </div>
                                    <div class="flex-grow-1 border-start ps-3">
                                        <p class="mb-0 fw-bold">@Model.CheckInDate.ToString("dddd")</p>
                                        <p class="mb-0 text-muted small">Từ 14:00</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6 border-top pt-3">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="me-3 text-center" style="width: 60px;">
                                        <div class="small text-muted uppercase">TRẢ</div>
                                        <div class="fs-4 fw-bold">@Model.CheckOutDate.Day</div>
                                        <div class="small">Tháng @Model.CheckOutDate.Month</div>
                                    </div>
                                    <div class="flex-grow-1 border-start ps-3">
                                        <p class="mb-0 fw-bold">@Model.CheckOutDate.ToString("dddd")</p>
                                        <p class="mb-0 text-muted small">Trước 12:00</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center bg-info bg-opacity-10 p-3 rounded mb-4 border border-info border-opacity-25">
                        <div>
                            <h5 class="fw-bold mb-0">Tổng cộng:</h5>
                            <p class="text-muted small mb-0">Đã bao gồm thuế và phí</p>
                        </div>
                        <div class="text-end">
                            <h3 class="fw-bold mb-0 text-primary">@Model.TotalPrice.ToString("N0") VND</h3>
                        </div>
                    </div>

                    <div class="alert alert-warning d-flex align-items-center" role="alert">
                        <i class="fa-solid fa-circle-info me-3 fs-4"></i>
                        <div>
                            Thông tin xác nhận đã được gửi đến email của bạn. Quý khách vui lòng kiểm tra hộp thư.
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-5">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-booking btn-lg px-5">Quay lại trang chủ</a>
                        <button onclick="window.print()" class="btn btn-outline-secondary btn-lg px-4">
                            <i class="fa-solid fa-print me-2"></i>In hóa đơn
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
